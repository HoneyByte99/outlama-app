// Copy this file to Secrets.xcconfig (gitignored) and fill in real values.
// Secrets.xcconfig is loaded by Debug.xcconfig and Release.xcconfig via
// `#include? "Secrets.xcconfig"` — the `?` makes it optional so the build
// succeeds in CI where keys are injected via environment variables instead.
//
// WARNING: Never commit Secrets.xcconfig to version control.

MAPS_API_KEY = YOUR_GOOGLE_MAPS_IOS_API_KEY_HERE
